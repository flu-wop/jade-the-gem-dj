d:["$","$1","c",{"children":[["$","div",null,{"className":"min-h-screen pt-24 pb-24 px-4","children":["$","div",null,{"className":"max-w-6xl mx-auto","children":[["$","header",null,{"className":"text-center mb-16","children":[["$","p",null,{"className":"section-label","children":"The Story"}],["$","h1",null,{"className":"section-title","children":["About ",["$","span",null,{"className":"text-neon-green","children":"Jade"}]]}]]}],["$","div",null,{"className":"grid grid-cols-1 lg:grid-cols-2 gap-12 mb-20","children":[["$","div",null,{"className":"space-y-8","children":[["$","div",null,{"className":"card p-8","children":[["$","h2",null,{"className":"font-display text-3xl text-neon-green mb-4","children":"504 Creative"}],["$","div",null,{"className":"neon-divider"}],["$","div",null,{"className":"space-y-4 text-white/60 leading-relaxed text-sm mt-4","children":[["$","p",null,{"children":"Born and raised in the vibrant heart of New Orleans, DJ Jade the Gem has been setting dance floors on fire across the Gulf Coast and beyond. With a sound rooted in the 504 — bounce, hip-hop, R&B, and club bangers — Jade creates an atmosphere where the music does the talking and the crowd never wants it to stop."}],["$","p",null,{"children":"What started as a passion for records, mixing, and making people move has grown into a full career of headline sets, festival slots, and private events that people talk about long after the last track fades. Jade's signature is simple: reading the room, matching the vibe, and pushing it further than anyone expected."}],["$","p",null,{"children":"Off the decks you'll find her in the studio crafting new mixes, hunting for the next hidden gem of a record, or building 504 Creative — her brand dedicated to celebrating New Orleans talent and culture on a world stage."}]]}]]}],["$","div",null,{"className":"card p-6","children":[["$","h3",null,{"className":"font-display text-2xl text-neon-purple mb-5","children":"Connect"}],["$","div",null,{"className":"space